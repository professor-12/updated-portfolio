---
import Scatter from "./Scatter.astro";

const links = [
    { name: "Email /", href: "mailto:badejoemmanuel805@gmail.com" },
    { name: "Github /", href: "https://github.com/professor-12" },
    {
        name: "LinkedIn /",
        href: "https://www.linkedin.com/in/badejo-emmanuel-890414293",
    },
    { name: "Blog", href: "https://blog.bigdev.uk" },
];

// Open off-site links in a new tab; keep in-page/mailto links in place.
const isExternal = (href: string) => /^https?:\/\//.test(href);
---

<header
    class="w-full mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between py-2"
>
    <div>
        <Scatter
            text="~/Big dev"
            display="inline"
            size="xs"
            repel={10}
            hoverColor="orange"
        />
    </div>
    <div class="w-full sm:w-auto">
        <nav
            class="flex flex-wrap gap-x-4 gap-y-2 justify-start sm:justify-center items-center px-0 sm:px-6 py-1 sm:py-3"
        >
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        target={isExternal(link.href) ? "_blank" : undefined}
                        rel={
                            isExternal(link.href)
                                ? "noopener noreferrer"
                                : undefined
                        }
                    >
                        <Scatter
                            as="span"
                            text={link.name}
                            display="inline"
                            color="#ffffff"
                            hoverColor="orange"
                            size="xs"
                            repel={10}
                        />
                    </a>
                ))
            }
        </nav>
    </div>
</header>
