---
// ScatterImage.astro
// Usage: <ScatterImage src="/photo.jpg" width={600} height={400} />
//
// Props:
//   src         — image path (required)
//   width       — display width in px (default 600)
//   height      — display height in px (default 400)
//   dotSpacing  — px between dot samples (default 6)
//   dotRadius   — dot radius in px (default 2)
//   repel       — cursor repel radius (default 100)
//   strength    — repel force (default 20)
//   spring      — snap-back speed (default 0.07)
//   friction    — damping 0–1 (default 0.76)
//   threshold   — min alpha 0–255 to include a dot (default 30)
//   grayscale   — render all dots in one color instead of sampled (default false)
//   color       — dot color when grayscale=true (default "#ffffff")

interface Props {
  src: string;
  width?: number;
  height?: number;
  dotSpacing?: number;
  dotRadius?: number;
  repel?: number;
  strength?: number;
  spring?: number;
  friction?: number;
  threshold?: number;
  grayscale?: boolean;
  color?: string;
  class?: string;
}

const {
  src,
  width = 600,
  height = 400,
  dotSpacing = 6,
  dotRadius = 2,
  repel = 100,
  strength = 20,
  spring = 0.07,
  friction = 0.76,
  threshold = 30,
  grayscale = false,
  color = '#ffffff',
  class: className = '',
} = Astro.props;
---

<div
  class={`scatter-image-host ${className}`}
  style={`position:relative;width:${width}px;height:${height}px;display:inline-block;`}
  data-si-src={src}
  data-si-width={width}
  data-si-height={height}
  data-si-spacing={dotSpacing}
  data-si-radius={dotRadius}
  data-si-repel={repel}
  data-si-strength={strength}
  data-si-spring={spring}
  data-si-friction={friction}
  data-si-threshold={threshold}
  data-si-grayscale={grayscale ? '1' : '0'}
  data-si-color={color}
  aria-label="Scatter image"
>
  <canvas style="position:absolute;top:0;left:0;" aria-hidden="true"></canvas>
  <!-- Visually hidden img for accessibility -->
  <img src={src} alt="" style="opacity:0;position:absolute;width:1px;height:1px;" aria-hidden="true" />
</div>

<script>
interface Dot {
  ox: number; oy: number;
  x:  number; y:  number;
  vx: number; vy: number;
  // Pre-computed fill colour for this dot. Building the rgba() string here once
  // (instead of every frame) removes thousands of allocations + toFixed calls
  // per frame — the main source of GC churn for dense images.
  cs: string;
}

interface SIInstance {
  host:   HTMLElement;
  canvas: HTMLCanvasElement;
  ctx:    CanvasRenderingContext2D;
  dots:   Dot[];
  cfg: {
    repel: number; strength: number;
    spring: number; friction: number;
    dotRadius: number;
    grayscale: boolean; color: string;
  };
  // perf flags: only animate what's on screen and not already at rest
  visible:  boolean;
  settled:  boolean;
}

const mouse = { x: -9999, y: -9999 };
const instances: SIInstance[] = [];
let rafStarted = false;

// Marks an instance off-screen (skipped in the loop) until it scrolls in.
const visObserver =
  typeof IntersectionObserver !== 'undefined'
    ? new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            const inst = instances.find((i) => i.host === e.target);
            if (inst) {
              inst.visible = e.isIntersecting;
              if (e.isIntersecting) inst.settled = false; // repaint on re-entry
            }
          }
        },
        { rootMargin: '100px' },
      )
    : null;

function sampleImage(
  img: HTMLImageElement,
  targetW: number,
  targetH: number,
  spacing: number,
  threshold: number,
): { r:number; g:number; b:number; a:number; ox:number; oy:number }[] {
  const off = document.createElement('canvas');
  off.width  = targetW;
  off.height = targetH;
  const oc = off.getContext('2d')!;
  oc.drawImage(img, 0, 0, targetW, targetH);
  const { data } = oc.getImageData(0, 0, targetW, targetH);

  const dots = [];
  for (let y = 0; y < targetH; y += spacing) {
    for (let x = 0; x < targetW; x += spacing) {
      const i = (y * targetW + x) * 4;
      const a = data[i + 3];
      if (a > threshold) {
        dots.push({ r: data[i], g: data[i+1], b: data[i+2], a, ox: x, oy: y });
      }
    }
  }
  return dots;
}

function initHost(host: HTMLElement) {
  const src       = host.dataset.siSrc!;
  const width     = parseInt(host.dataset.siWidth!);
  const height    = parseInt(host.dataset.siHeight!);
  const spacing   = parseInt(host.dataset.siSpacing!);
  const dotRadius = parseFloat(host.dataset.siRadius!);
  const repel     = parseFloat(host.dataset.siRepel!);
  const strength  = parseFloat(host.dataset.siStrength!);
  const spring    = parseFloat(host.dataset.siSpring!);
  const friction  = parseFloat(host.dataset.siFriction!);
  const threshold = parseInt(host.dataset.siThreshold!);
  const grayscale = host.dataset.siGrayscale === '1';
  const color     = host.dataset.siColor!;

  const canvas = host.querySelector('canvas')!;
  canvas.width  = width;
  canvas.height = height;
  const ctx = canvas.getContext('2d')!;

  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.src = src;

  img.onload = () => {
    const sampled = sampleImage(img, width, height, spacing, threshold);
    const dots: Dot[] = sampled.map(s => ({
      ox: s.ox, oy: s.oy,
      x:  s.ox, y:  s.oy,
      vx: 0,    vy: 0,
      // Bake the fill colour once. Grayscale dots all share cfg.color.
      cs: grayscale
        ? color
        : `rgba(${s.r},${s.g},${s.b},${(s.a / 255).toFixed(2)})`,
    }));

    const inst: SIInstance = {
      host, canvas, ctx, dots,
      cfg: { repel, strength, spring, friction, dotRadius, grayscale, color },
      visible: true,
      settled: false,
    };
    instances.push(inst);
    visObserver?.observe(host);

    if (!rafStarted) {
      rafStarted = true;
      requestAnimationFrame(tick);
    }
  };
}

function tick() {
  for (const inst of instances) {
    // Skip anything scrolled out of view — zero work while off-screen.
    if (!inst.visible) continue;

    const { canvas, ctx, dots, cfg } = inst;
    const w = canvas.width;
    const h = canvas.height;

    const rect = canvas.getBoundingClientRect();
    const mx   = mouse.x - rect.left - window.scrollX;
    const my   = mouse.y - rect.top  - window.scrollY;

    // Is the cursor close enough to disturb any dot in this canvas?
    const mouseNear =
      mx > -cfg.repel && mx < w + cfg.repel &&
      my > -cfg.repel && my < h + cfg.repel;

    // Settled + cursor away => keep the last painted frame, do nothing.
    if (inst.settled && !mouseNear) continue;

    ctx.clearRect(0, 0, w, h);

    const r      = cfg.dotRadius;
    const repel2 = cfg.repel * cfg.repel;
    let moving   = false;

    // Resting dots are batched per colour into one Path2D and filled in a
    // single call per colour, instead of a beginPath/fill per dot.
    const restPaths = new Map<string, Path2D>();

    for (const d of dots) {
      const dx = d.x - mx;
      const dy = d.y - my;
      const d2 = dx * dx + dy * dy;

      if (d2 < repel2 && d2 > 0) {
        const dist    = Math.sqrt(d2);
        const force   = (cfg.repel - dist) / cfg.repel;
        d.vx += (dx / dist) * force * cfg.strength;
        d.vy += (dy / dist) * force * cfg.strength;

        const angle   = Math.atan2(dy, dx);
        const stretch = 1 + force * 3.5;

        ctx.save();
        ctx.translate(d.x, d.y);
        ctx.rotate(angle);
        ctx.beginPath();
        ctx.ellipse(0, 0, r * stretch, r * 0.55, 0, 0, Math.PI * 2);
        ctx.fillStyle   = d.cs;
        ctx.globalAlpha = 0.4 + force * 0.6;
        ctx.fill();
        ctx.restore();
        ctx.globalAlpha = 1;
      } else {
        let path = restPaths.get(d.cs);
        if (!path) restPaths.set(d.cs, (path = new Path2D()));
        // moveTo prevents a connecting line from the previous arc.
        path.moveTo(d.x + r, d.y);
        path.arc(d.x, d.y, r, 0, Math.PI * 2);
      }

      d.vx += (d.ox - d.x) * cfg.spring;
      d.vy += (d.oy - d.y) * cfg.spring;
      d.vx *= cfg.friction;
      d.vy *= cfg.friction;
      d.x  += d.vx;
      d.y  += d.vy;

      if (
        Math.abs(d.vx) > 0.05 ||
        Math.abs(d.vy) > 0.05 ||
        Math.abs(d.x - d.ox) > 0.05 ||
        Math.abs(d.y - d.oy) > 0.05
      ) {
        moving = true;
      }
    }

    // One fill per distinct colour for all the resting dots.
    for (const [cs, path] of restPaths) {
      ctx.fillStyle = cs;
      ctx.fill(path);
    }

    // Once the cursor leaves and every dot is home, stop redrawing.
    inst.settled = !mouseNear && !moving;
  }

  requestAnimationFrame(tick);
}

window.addEventListener('mousemove', e => {
  mouse.x = e.clientX + window.scrollX;
  mouse.y = e.clientY + window.scrollY;
});
window.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll<HTMLElement>('.scatter-image-host').forEach(initHost);
});
</script>