---
import Layout from "../layouts/Layout.astro";
import Scatter from "../components/Scatter.astro";
import ScatterImage from "../components/ScatterImage.astro";
import SelectedWork from "../components/SelectedWork.astro";


import shot from "../assets/shot.png";
const about = `I BUILD AND SHIP SOFTWARE PRODUCTS END TO END. THE SIMPLE WAY TO PUT IT: YOU GIVE ME A PROBLEM OR GOAL, AND I TURN IT INTO A WORKING, SCALABLE PRODUCT. I OPERATE ACROSS THE FULL-STACK FROM UI/UX IMPLEMENTATION TO API DESIGN, PERFORMANCE OPTIMIZATION, AND PRODUCTION DEPLOYMENT. I CARE ABOUT BUILDING THINGS THAT ARE NOT JUST FUNCTIONAL, BUT CLEAN, MAINTAINABLE, AND FAST.`;

const about2 = `
BEFORE THIS, I’VE WORKED EXTENSIVELY WITH MODERN JAVASCRIPT STACKS LIKE REACT, TYPESCRIPT, AND NODE.JS, BUILDING USER-FACING APPLICATIONS AND DATA-HEAVY INTERFACES.`;

// Render each paragraph as its own scatter instance instead of one giant one.
// Each chunk is a separate canvas, so the engine can skip the ones that are
// off-screen or sitting idle — only the chunk under the cursor does work.
const aboutChunks = about
	.split(/\n\s*\n/)
	.map((p) => p)
	.filter(Boolean);

const aboutChunks2 = about2
	.split(/\n\s*\n/)
	.map((p) => p)
	.filter(Boolean);

// 👇 Edit this one number to control how wide the about text wraps (px).
// It auto-shrinks on screens narrower than this.
const aboutWidth = 600;
---

<Layout>
	<main class="mt-8 flex items-center justify-between md:mt-15">
		<!-- Portrait + text: stacked on mobile, side by side from md up -->
		<div
			class="flex w-[70%] flex-col md:flex-row gap-8 md:gap-12 md:items-center"
		>
			<div class="w-full md:w-full">
				<!-- Heading scales up with the viewport; block mode reflows to fit -->
				<Scatter
					as="h1"
					text="Emmanuel Adewale"
					size="sm"
					sizeMd="md"
					display="inline"
					sizeLg="lg"
				/>
				<br />
				<Scatter
					as="span"
					text="18 years old Software Engineer"
					size="xs"
					display="inline"
					class="text-red-400"
				/>

				<!-- One Scatter per paragraph: smaller canvases, lazy-animated -->
				<div class="mt-6 w-full flex flex-col gap-4">
					{
						aboutChunks.map((chunk) => (
							<Scatter
								text={chunk}
								as="span"
								size="xs"
								width={aboutWidth}
								gap={2.1}
								dotR={1}
								charGap={3}
								lineGap={6}
								strength={14}
								spring={0.1}
								wordGap={-1}
								repel={10}
							/>
						))
					}
				</div>
				<div class="mt-6 w-full flex flex-col gap-4">
					{
						aboutChunks2.map((chunk) => (
							<Scatter
								text={chunk}
								as="span"
								size="xs"
								width={aboutWidth}
								gap={2}
								dotR={0.8}
								charGap={3}
								lineGap={6}
								strength={14}
								spring={0.1}
								wordGap={-1}
								repel={10}
							/>
						))
					}
			</div>
		</div>
	</main>
	<SelectedWork/>	
</Layout>
